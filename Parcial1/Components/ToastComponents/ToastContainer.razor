@using Parcial1.Services.Toast
@inject Parcial1.Services.Toast.IToastService ToastService

<div class="toast-stack">
    @foreach (var toast in ToastService.Items)
    {
        <div class="@toast.Level.ToCss()">
            <div class="toast-body">
                <strong>@toast.Title</strong>
                <div>@toast.Message</div>
            </div>

            <button type="button" class="toast-close" @onclick="() => ToastService.Dismiss(toast.Id)">×</button>
        </div>
    }
</div>

@code {
    protected override void OnInitialized()
    {
        ToastService.OnChange += StateHasChanged;
    }

    public void Dispose()
    {
        ToastService.OnChange -= StateHasChanged;
    }
}
