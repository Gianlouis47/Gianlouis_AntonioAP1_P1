@page "/entradas-huacales/editar/{IdEntrada:int}"

@using Parcial1.Models
@using Parcial1.Services
@using Parcial1.Extensors
@using BlazorBootstrap

@inject NavigationManager Nav
@inject EntradasHuacalesServices Service
@inject TiposHuacalesServices TiposService
@inject ToastService toastService

<PageTitle>Editar Entrada</PageTitle>


@if (Model == null)
{
    <div class="cardx">
        <div class="muted">
            Entrada no encontrada
        </div>
    </div>
}
else
{

    <EditForm Model="Model" OnValidSubmit="SaveAsync">

        <DataAnnotationsValidator />
        <ValidationSummary />


        <!-- DATOS GENERALES -->
        <div class="cardx">

            <div class="form-grid">

                <div class="fx">
                    <label>Fecha</label>
                    <InputDate class="form-control"
                               @bind-Value="Model.Fecha" />
                </div>

                <div class="fx">
                    <label>Cliente</label>
                    <InputText class="form-control"
                               @bind-Value="Model.NombreCliente" />
                </div>

                <div class="fx">
                    <label>Cantidad total</label>
                    <InputNumber class="form-control"
                                 @bind-Value="Model.Cantidad" />
                </div>

                <div class="fx">
                    <label>Precio base</label>
                    <InputNumber class="form-control"
                                 @bind-Value="Model.Precio" />
                </div>

            </div>

        </div>


        <!-- DETALLES -->
        <div class="cardx mt-3">

            <div class="d-flex justify-content-between align-items-center mb-2">

                <h5>Detalles</h5>

                <div>

                    <!-- TriggerSelection -->
                    <button type="button"
                            class="btn btn-brand"
                            @onclick="AddDetalle">

                        + Agregar detalle

                    </button>

                    <button type="button"
                            class="btn btn-outline-light ms-2"
                            @onclick="ToggleCrearTipo">

                        + Nuevo tipo

                    </button>

                </div>

            </div>


            <!-- CREAR TIPO -->
            @if (MostrarCrearTipo)
            {
                <div class="cardx mb-3">

                    <div class="form-grid">

                        <div class="fx">
                            <label>Descripción</label>
                            <InputText class="form-control"
                                       @bind-Value="NuevoTipo.Descripcion" />
                        </div>

                        <div class="fx">
                            <label>Existencia</label>
                            <InputNumber class="form-control"
                                         @bind-Value="NuevoTipo.Existencia" />
                        </div>

                        <div class="fx">
                            <label>Color HEX</label>
                            <InputText class="form-control"
                                       placeholder="#ff0000"
                                       @bind-Value="NuevoTipo.ColorHex" />
                        </div>

                    </div>

                    <div class="form-actions mt-2">

                        <button type="button"
                                class="btn btn-success"
                                @onclick="CrearTipoAsync">

                            Guardar tipo

                        </button>

                        <button type="button"
                                class="btn btn-secondary"
                                @onclick="CancelarTipo">

                            Cancelar

                        </button>

                    </div>

                </div>
            }


            <!-- TABLA -->
            <table class="table table-darkx">

                <thead>

                    <tr>
                        <th>Tipo</th>
                        <th>Cantidad</th>
                        <th>Existencia</th>
                        <th>Color</th>
                        <th></th>
                    </tr>

                </thead>

                <tbody>

                    @if (!Model.Detalles.Any())
                    {
                        <tr>
                            <td colspan="5" class="muted">
                                No hay detalles
                            </td>
                        </tr>
                    }

                    @foreach (var detalle in Model.Detalles)
                    {
                        var tipo = Tipos.FirstOrDefault(x => x.TipoId == detalle.TipoId);

                        <tr>

                            <td>

                                <InputSelect class="form-control"
                                             @bind-Value="detalle.TipoId">

                                    <option value="0">
                                        Seleccione tipo
                                    </option>

                                    @foreach (var t in Tipos)
                                    {
                                        <option value="@t.TipoId">
                                            @t.Descripcion
                                        </option>
                                    }

                                </InputSelect>

                            </td>

                            <td>

                                <InputNumber class="form-control"
                                             @bind-Value="detalle.Cantidad" />

                            </td>

                            <td>

                                @if (tipo != null)
                                {
                                    <span class="badge bg-info">
                                        @tipo.Existencia
                                    </span>
                                }

                            </td>

                            <td>

                                @if (tipo != null)
                                {
                                    <span style="
                                        display:inline-block;
                                        width:20px;
                                        height:20px;
                                        border-radius:4px;
                                        background:@tipo.ColorHex;">
                                    </span>
                                }

                            </td>

                            <td>

                                <button type="button"
                                        class="btn btn-danger btn-sm"
                                        @onclick="() => RemoveDetalle(detalle)">

                                    Eliminar

                                </button>

                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>


        <!-- BOTONES -->
        <div class="form-actions mt-3">

            <button type="submit"
                    class="btn btn-primary">

                Guardar cambios

            </button>

            <button type="button"
                    class="btn btn-secondary"
                    @onclick="Back">

                Cancelar

            </button>

        </div>

    </EditForm>

}


@code {

    [Parameter]
    public int IdEntrada { get; set; }


    private EntradasHuacales? Model;

    private List<TiposHuacales> Tipos = new();

    private TiposHuacales NuevoTipo = new();

    private bool MostrarCrearTipo = false;


    protected override async Task OnInitializedAsync()
    {
        await CargarTipos();

        Model = await Service.GetByIdAsync(IdEntrada);

        if (Model == null)
            return;

        if (Model.Detalles == null)
            Model.Detalles = new List<DetalleHuacales>();
    }


    private async Task CargarTipos()
    {
        Tipos = await TiposService.GetAsync();
        StateHasChanged();
    }


    private void AddDetalle()
    {
        Model?.Detalles.Add(new DetalleHuacales
        {
            TipoId = 0,
            Cantidad = 1,
            Precio = Model.Precio
        });
    }


    private void RemoveDetalle(DetalleHuacales detalle)
    {
        Model?.Detalles.Remove(detalle);
    }


    private async Task SaveAsync()
    {
        try
        {
            await Service.UpdateAsync(Model!);

            toastService.ShowSuccess("Entrada actualizada correctamente");

            Nav.NavigateTo("/entradas-huacales");
        }
        catch (Exception ex)
        {
            toastService.ShowError(ex.Message);
        }
    }


    private void ToggleCrearTipo()
    {
        MostrarCrearTipo = !MostrarCrearTipo;
    }


    private async Task CrearTipoAsync()
    {
        try
        {
            await TiposService.CreateAsync(NuevoTipo);

            NuevoTipo = new();

            MostrarCrearTipo = false;

            await CargarTipos();

            toastService.ShowSuccess("Tipo creado correctamente");
        }
        catch (Exception ex)
        {
            toastService.ShowError(ex.Message);
        }
    }


    private void CancelarTipo()
    {
        MostrarCrearTipo = false;
        NuevoTipo = new();
    }


    private void Back()
    {
        Nav.NavigateTo("/entradas-huacales");
    }

}