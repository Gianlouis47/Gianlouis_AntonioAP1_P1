@using Parcial1.Models
@page "/EntradasHuacales/Edit/{IdEntrada:int}"
@using Parcial1.Services 
@inject NavigationManager Nav
@inject Parcial1.Services.EntradasHuacalesServices Service

<div class="page-head">
    <div>
        <div class="page-title">Editar entrada</div>
        <div class="page-subtitle">Actualizar datos</div>
    </div>
</div>

<div class="cardx">
    @if (Model is null)
    {
        <div class="muted">Not found.</div>
    }
    else
    {
        @if (!string.IsNullOrEmpty(error))
        {
            <div class="alert alert-danger">@error</div>
        }

        <form @onsubmit="SaveAsync">
            <div class="form-grid">
                <div class="fx">
                    <label class="flabel">Fecha</label>
                    <input type="date" class="form-control finput" @bind="Model.Fecha" required />
                </div>

                <div class="fx">
                    <label class="flabel">Cliente</label>
                    <input type="text" class="form-control finput" @bind="Model.NombreCliente" required />
                </div>

                <div class="fx">
                    <label class="flabel">Cantidad</label>
                    <input type="number" class="form-control finput" @bind="Model.Cantidad" required />
                </div>

                <div class="fx">
                    <label class="flabel">Precio</label>
                    <input type="number" step="0.01" class="form-control finput" @bind="Model.Precio" required />
                </div>
            </div>

            <div class="form-actions">
                <button class="btn btn-brand" type="submit">Guardar</button>
                <button class="btn btn-ghost" type="button" @onclick="Back">Cancelar</button>
            </div>
        </form>
    }
</div>

@code {
    [Parameter] public int IdEntrada { get; set; }

    private EntradaHuacales Model { get; set; }
    private string error = "";

    protected override async Task OnParametersSetAsync()
    {
        Model = await Service.GetByIdAsync(IdEntrada);
    }

    private async Task SaveAsync()
    {
        error = "";

        if (Model is null)
        {
            error = "No se encontró el registro.";
            return;
        }

        if (string.IsNullOrWhiteSpace(Model.NombreCliente))
        {
            error = "El nombre del cliente es requerido.";
            return;
        }

        if (Model.Cantidad <= 0)
        {
            error = "La cantidad debe ser mayor a 0.";
            return;
        }

        if (Model.Precio <= 0)
        {
            error = "El precio debe ser mayor a 0.";
            return;
        }

        try
        {
            await Service.UpdateAsync(Model);
            Nav.NavigateTo("/EntradasHuacales");
        }
        catch (Exception ex)
        {
            error = $"Error al guardar: {ex.Message}";
        }
    }

    private void Back() => Nav.NavigateTo("/EntradasHuacales");
}
