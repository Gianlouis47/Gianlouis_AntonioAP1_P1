@page "/EntradaHuacales/Index"
@page "/EntradasHuacales"
@layout MainLayout
@using Parcial1.Models
@inject Parcial1.Services.EntradasHuacalesServices Service
@inject NavigationManager Navigation

<div class="card mt-4">
    <div class="card-header">
        <h2>Registro de Entradas de Huacales</h2>
    </div>

    <div class="card-body">

        <div class="row mb-3">
            <div class="col-md-6">
                <label>Filtrar por Cliente:</label>
                <input class="form-control"
                       @bind="filtroCliente" />
            </div>

            <div class="col-md-2 d-flex align-items-end">
                <button class="btn btn-outline-primary"
                        @onclick="Buscar">
                    Buscar
                </button>
            </div>

            <div class="col-md-4 text-end">
                <a class="btn btn-success" href="/EntradasHuacales/Create">Crear Nuevo</a>
            </div>
        </div>

        <table class="table table-bordered">
            <thead class="table-light">
                <tr>
                    <th>IDENTIFICACIÓN</th>
                    <th>Fecha</th>
                    <th>Cliente</th>
                    <th>Cantidad</th>
                    <th>Precio</th>
                    <th>Acciones</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in lista)
                {
                    <tr>
                        <td>@item.IdEntrada</td>
                        <td>@item.Fecha.ToShortDateString()</td>
                        <td>@item.NombreCliente</td>
                        <td>@item.Cantidad</td>
                        <td>@item.Precio</td>
                        <td>
                            <button class="btn btn-sm btn-outline-primary me-2"
                                    @onclick="() => Editar(item.IdEntrada)">
                                Editar
                            </button>

                            <button class="btn btn-sm btn-outline-danger"
                                    @onclick="() => Eliminar(item.IdEntrada)">
                                Eliminar
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <hr />

        <p><strong>Conteo:</strong> @lista.Count</p>
        <p><strong>Cantidad total:</strong> @lista.Sum(x => x.Cantidad)</p>

    </div>
</div>

@code {

    private List<EntradaHuacales> lista = new();
    private string filtroCliente = "";

    protected override async Task OnInitializedAsync()
    {
        lista = await Service.GetAllAsync();
    }

    private async Task Buscar()
    {
        lista = await Service.GetAllAsync();
    }

    private void Crear()
    {
        Navigation.NavigateTo("/EntradasHuacales/Create");
    }

    private void Editar(int id)
    {
        Navigation.NavigateTo($"/EntradasHuacales/Edit/{id}");
    }

    private async Task Eliminar(int id)
    {
        await Service.DeleteAsync(id);
        lista = await Service.GetAllAsync();
    }
}


        
