@page "/entradas-huacales"

@using Parcial1.Models
@using Parcial1.Services
@using Parcial1.Extensors
@using Microsoft.AspNetCore.Components.QuickGrid
@using BlazorBootstrap

@inject NavigationManager Nav
@inject IJSRuntime JS
@inject EntradasHuacalesServices Service
@inject ToastService ToastService

<div class="page-head">

    <div>
        <div class="page-title">Entradas de Huacales</div>
        <div class="page-subtitle">
            Registro con detalle
        </div>
    </div>

    <button class="btn btn-brand"
            @onclick="GoCreate">

        + Nueva entrada

    </button>

</div>



<div class="cardx table-wrap">

    <QuickGrid TGridItem="EntradasHuacales"
               Items="Items.AsQueryable()"
               class="table table-darkx">

        <!-- ID -->
        <PropertyColumn Property="x => x.IdEntrada"
                        Title="Id"
                        Sortable="true"
                        InitialSortDirection="Microsoft.AspNetCore.Components.QuickGrid.SortDirection.Ascending" />

        <!-- FECHA -->
        <PropertyColumn Property="x => x.Fecha"
                        Title="Fecha"
                        Sortable="true" />

        <!-- CLIENTE -->
        <PropertyColumn Property="x => x.NombreCliente"
                        Title="Cliente"
                        Sortable="true" />

        <!-- CANTIDAD -->
        <PropertyColumn Property="x => x.Cantidad"
                        Title="Cantidad"
                        Sortable="true"
                        Class="t-right" />

        <!-- PRECIO -->
        <PropertyColumn Property="x => x.Precio"
                        Title="Precio"
                        Sortable="true"
                        Class="t-right" />

        <!-- TOTAL -->
        <PropertyColumn Property="x => x.Total"
                        Title="Total"
                        Sortable="true"
                        Class="t-right" />

        <!-- DETALLES -->
        <TemplateColumn Title="Detalles">

            @context.Detalles.Count

        </TemplateColumn>

        <!-- ACCIONES -->
        <TemplateColumn Title="Acciones">

            <button class="btn btn-sm btn-edit"
                    @onclick="() => GoEdit(context.IdEntrada)">

                Editar

            </button>

            <button class="btn btn-sm btn-danger"
                    @onclick="() => DeleteAsync(context.IdEntrada)">

                Eliminar

            </button>

        </TemplateColumn>

    </QuickGrid>

</div>



<div class="footer-metrics">

    <div class="metric">
        <div class="m-label">Conteo</div>
        <div class="m-value">
            @Items.Count
        </div>
    </div>

    <div class="metric">
        <div class="m-label">Total cantidad</div>
        <div class="m-value">
            @TotalCantidad
        </div>
    </div>

    <div class="metric">
        <div class="m-label">Total monto</div>
        <div class="m-value">
            @TotalMonto.ToString("N2")
        </div>
    </div>

</div>



@code {

    private List<EntradasHuacales> Items = new();


    private int TotalCantidad =>
        Items.Sum(x => x.Cantidad);


    private decimal TotalMonto =>
        Items.Sum(x => x.Total);


    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }


    private async Task LoadAsync()
    {
        try
        {
            Items = await Service.GetAsync();
        }
        catch (Exception ex)
        {
            ToastService.ShowError(ex.Message);
        }
    }


    private void GoCreate()
        => Nav.NavigateTo("/entradas-huacales/nuevo");


    private void GoEdit(int id)
        => Nav.NavigateTo($"/entradas-huacales/editar/{id}");


    private async Task DeleteAsync(int id)
    {
        var ok = await JS.InvokeAsync<bool>(
            "confirm",
            $"Eliminar entrada #{id}?"
        );

        if (!ok)
            return;

        try
        {
            await Service.DeleteAsync(id);

            ToastService.ShowSuccess("Registro eliminado");

            await LoadAsync();
        }
        catch (Exception ex)
        {
            ToastService.ShowError(ex.Message);
        }
    }

}