@page "/EntradasHuacales/Index"

@using Parcial1.Models
@using Parcial1.Services

@inject EntradasHuacalesService entradasHuacalesService

<div class="container-fluid">

    <div class="card shadow-lg mt-3">

        <!-- HEADER -->
        <div class="card-header bg-light d-flex justify-content-between align-items-center">

            <h5 class="card-title mb-0">
                Registro de Entradas de Huacales
            </h5>

            <a href="/EntradasHuacales/Create"
               class="btn btn-success">
                <i class="bi bi-plus-lg"></i>
                Crear Nuevo
            </a>

        </div>

        <!-- BODY -->
        <div class="card-body">

            <!-- FILTROS RESPONSIVE -->
            <div class="row g-2">

                <div class="col-12 col-md-2">
                    <InputNumber class="form-control"
                                 @bind-Value="FiltroId"
                                 placeholder="Id" />
                </div>

                <div class="col-12 col-md-3">
                    <InputText class="form-control"
                               @bind-Value="FiltroNombre"
                               placeholder="Cliente" />
                </div>

                <div class="col-12 col-md-2">
                    <InputNumber class="form-control"
                                 @bind-Value="FiltroCantidad"
                                 placeholder="Cantidad" />
                </div>

                <div class="col-12 col-md-2">
                    <InputNumber class="form-control"
                                 @bind-Value="FiltroPrecio"
                                 placeholder="Precio" />
                </div>

                <div class="col-12 col-md-3">
                    <button class="btn btn-primary w-100"
                            @onclick="Buscar">

                        <i class="bi bi-search"></i>
                        Buscar

                    </button>
                </div>

            </div>

            <!-- FECHAS -->
            <div class="row g-2 mt-2">

                <div class="col-12 col-md-3">

                    <label class="form-label">
                        Desde
                    </label>

                    <InputDate class="form-control"
                               @bind-Value="FechaDesde" />

                </div>

                <div class="col-12 col-md-3">

                    <label class="form-label">
                        Hasta
                    </label>

                    <InputDate class="form-control"
                               @bind-Value="FechaHasta" />

                </div>

            </div>

            <!-- GRID RESPONSIVE -->
            <div class="table-responsive mt-3">

                <QuickGrid TGridItem="EntradasHuacales"
                           Items="@ListaQuery"
                           class="table table-hover table-striped">

                    <PropertyColumn Property="e => e.IdEntrada"
                                    Title="Id" />

                    <PropertyColumn Property="e => e.Fecha"
                                    Title="Fecha" />

                    <PropertyColumn Property="e => e.NombreCliente"
                                    Title="Cliente" />

                    <PropertyColumn Property="e => e.Cantidad"
                                    Title="Cantidad" />

                    <PropertyColumn Property="e => e.Precio"
                                    Title="Precio" />

                    <TemplateColumn Title="Acciones">

                        <a class="btn btn-outline-primary btn-sm"
                           href="@($"/EntradasHuacales/Edit/{context.IdEntrada}")">

                            <i class="bi bi-pencil-square"></i>

                        </a>

                    </TemplateColumn>

                </QuickGrid>

            </div>

        </div>

        <!-- FOOTER -->
        <div class="card-footer bg-light d-flex justify-content-between">

            <div>
                <strong>
                    Cantidad:
                </strong>
                @ListaQuery.Count()
            </div>

            <div>
                <strong>
                    Total:
                </strong>
                @TotalPrecio.ToString("C")
            </div>

        </div>

    </div>

</div>


@code {

    public List<EntradasHuacales> ListaEntradas = new();

    public IQueryable<EntradasHuacales> ListaQuery =
        Enumerable.Empty<EntradasHuacales>().AsQueryable();

    public double TotalPrecio = 0;

    public string? FiltroNombre;

    public int? FiltroId;

    public int? FiltroCantidad;

    public double? FiltroPrecio;

    public DateTime? FechaDesde;

    public DateTime? FechaHasta;


    protected override async Task OnInitializedAsync()
    {
        ListaEntradas =
            await entradasHuacalesService.Listar(e => true);

        if (ListaEntradas.Any())
        {
            FechaDesde =
                ListaEntradas.Min(e => e.Fecha);

            FechaHasta =
                ListaEntradas.Max(e => e.Fecha);
        }

        AplicarFiltro();
    }


    private void Buscar()
    {
        AplicarFiltro();
    }


    private void AplicarFiltro()
    {

        var query =
            ListaEntradas.AsQueryable();


        if (FiltroId.HasValue)
            query =
                query.Where(e =>
                    e.IdEntrada == FiltroId.Value);


        if (!string.IsNullOrWhiteSpace(FiltroNombre))
            query =
                query.Where(e =>
                    e.NombreCliente.ToLower()
                    .Contains(FiltroNombre.ToLower()));


        if (FiltroCantidad.HasValue)
            query =
                query.Where(e =>
                    e.Cantidad == FiltroCantidad.Value);


        if (FiltroPrecio.HasValue)
            query =
                query.Where(e =>
                    e.Precio == FiltroPrecio.Value);


        if (FechaDesde.HasValue)
            query =
                query.Where(e =>
                    e.Fecha.Date >= FechaDesde.Value.Date);


        if (FechaHasta.HasValue)
            query =
                query.Where(e =>
                    e.Fecha.Date <= FechaHasta.Value.Date);


        ListaQuery = query;


        TotalPrecio =
            query.Sum(e =>
                e.Cantidad * e.Precio);

    }

}