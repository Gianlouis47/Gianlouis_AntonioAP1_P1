@using Parcial1.Models
@page "/entradas-huacales/nuevo"
@using Parcial1.Services
@inject NavigationManager Nav
@inject Parcial1.Services.EntradasHuacalesServices Service


<div class="page-head">
    <div>
        <div class="page-title">Nueva entrada</div>
        <div class="page-subtitle">Registrar entrada de huacales</div>
    </div>
</div>

<div class="cardx">
    <EditForm Model="Model" OnValidSubmit="SaveAsync">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div class="form-grid">
            <div class="fx">
                <label class="flabel">Fecha</label>
                <InputDate class="form-control finput" @bind-Value="Model.Fecha" />
            </div>

            <div class="fx">
                <label class="flabel">Cliente</label>
                <InputText class="form-control finput" @bind-Value="Model.NombreCliente" />
            </div>

            <div class="fx">
                <label class="flabel">Cantidad</label>
                <InputNumber class="form-control finput" @bind-Value="Model.Cantidad" />
            </div>

            <div class="fx">
                <label class="flabel">Precio</label>
                <InputNumber class="form-control finput" @bind-Value="Model.Precio" />
            </div>
        </div>

        <div class="form-actions">
            <button class="btn btn-brand" type="submit">Guardar</button>
            <button class="btn btn-ghost" type="button" @onclick="Back">Cancelar</button>
        </div>
    </EditForm>
</div>

@code {
    private EntradasHuacales Model { get; set; } = new();

    private async Task SaveAsync()
    {
        await Service.CreateAsync(Model);
        Nav.NavigateTo("/entradas-huacales");
    }

    private void Back() => Nav.NavigateTo("/entradas-huacales");
}

