@page "/entradas-huacales/nuevo"

@using Parcial1.Models
@using Parcial1.Services
@using Parcial1.Extensors
@using BlazorBootstrap

@inject NavigationManager Nav
@inject EntradasHuacalesServices Service
@inject TiposHuacalesServices TiposService
@inject ToastService toastService

<PageTitle>Nueva Entrada</PageTitle>

<div class="page-head">
    <div>
        <div class="page-title">Nueva entrada</div>
        <div class="page-subtitle">Registro con detalle de huacales</div>
    </div>
</div>

<EditForm Model="Model" OnValidSubmit="SaveAsync">

    <DataAnnotationsValidator />
    <ValidationSummary />

    <!-- DATOS GENERALES -->
    <div class="cardx">

        <div class="form-grid">

            <div class="fx">
                <label class="flabel">Fecha</label>
                <InputDate class="form-control finput"
                           @bind-Value="Model.Fecha" />
            </div>

            <div class="fx">
                <label class="flabel">Cliente</label>
                <InputText class="form-control finput"
                           @bind-Value="Model.NombreCliente" />
            </div>

            <div class="fx">
                <label class="flabel">Cantidad total</label>
                <InputNumber class="form-control finput"
                             @bind-Value="Model.Cantidad" />
            </div>

            <div class="fx">
                <label class="flabel">Precio base</label>
                <InputNumber class="form-control finput"
                             @bind-Value="Model.Precio" />
            </div>

        </div>

    </div>


    <!-- DETALLES -->
    <div class="cardx mt-3">

        <div class="d-flex justify-content-between align-items-center mb-2">

            <div class="page-title">
                Detalles de huacales
            </div>

            <!-- TriggerSelection -->
            <button type="button"
                    class="btn btn-brand"
                    @onclick="AddDetalle">

                + Agregar detalle

            </button>

        </div>


        <table class="table table-darkx">

            <thead>
                <tr>

                    <th style="width:40%">Tipo de huacal</th>

                    <th style="width:20%">Cantidad</th>

                    <th style="width:20%">Existencia</th>

                    <th style="width:20%"></th>

                </tr>
            </thead>

            <tbody>

                @if (Model.Detalles.Count == 0)
                {
                    <tr>
                        <td colspan="4" class="muted">
                            No hay detalles agregados.
                        </td>
                    </tr>
                }

                @foreach (var detalle in Model.Detalles)
                {
                    var tipo = Tipos.FirstOrDefault(t => t.TipoId == detalle.TipoId);

                    <tr>

                        <!-- InputSelect -->
                        <td>

                            <InputSelect class="form-control"
                                         @bind-Value="detalle.TipoId">

                                <option value="0">
                                    Seleccione tipo
                                </option>

                                @foreach (var t in Tipos)
                                {
                                    <option value="@t.TipoId">
                                        @t.Descripcion
                                    </option>
                                }

                            </InputSelect>

                        </td>


                        <!-- Cantidad -->
                        <td>

                            <InputNumber class="form-control"
                                         @bind-Value="detalle.Cantidad" />

                        </td>


                        <!-- Existencia -->
                        <td>

                            @if (tipo != null)
                            {
                                <span class="badge bg-info">
                                    @tipo.Existencia
                                </span>
                            }

                        </td>


                        <!-- Eliminar -->
                        <td>

                            <button type="button"
                                    class="btn btn-danger btn-sm"
                                    @onclick="() => RemoveDetalle(detalle)">

                                Eliminar

                            </button>

                        </td>

                    </tr>
                }

            </tbody>

        </table>

    </div>


    <!-- BOTONES -->
    <div class="form-actions mt-3">

        <button class="btn btn-brand" type="submit">
            Guardar
        </button>

        <button type="button"
                class="btn btn-ghost"
                @onclick="Back">

            Cancelar

        </button>

    </div>

</EditForm>


@code {

    private EntradasHuacales Model { get; set; } = new();

    private List<TiposHuacales> Tipos = new();

    protected override async Task OnInitializedAsync()
    {
        Tipos = await TiposService.GetAsync();
    }


    // TriggerSelection
    private void AddDetalle()
    {
        Model.Detalles.Add(new DetalleHuacales
        {
            TipoId = 0,
            Cantidad = 1,
            Precio = Model.Precio
        });
    }


    private void RemoveDetalle(DetalleHuacales detalle)
    {
        Model.Detalles.Remove(detalle);
    }


    private async Task SaveAsync()
    {
        try
        {
            await Service.CreateAsync(Model);

            toastService.ShowSuccess("Entrada creada correctamente");

            Nav.NavigateTo("/entradas-huacales");
        }
        catch (Exception ex)
        {
            toastService.ShowError(ex.Message);
        }
    }


    private void Back()
    {
        Nav.NavigateTo("/entradas-huacales");
    }

}